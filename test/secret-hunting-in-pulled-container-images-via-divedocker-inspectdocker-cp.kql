DeviceProcessEvents
| where FileName in~ ("dive", "docker", "jq", "docker.exe")
| where ProcessCommandLine has "azurecr.io" and ProcessCommandLine has "dive"
    or (ProcessCommandLine has "docker inspect" and ProcessCommandLine has "Config.Env" and ProcessCommandLine has "grep" and ProcessCommandLine has "secret")
    or (ProcessCommandLine has "docker cp" and ProcessCommandLine has "extracted_container")
| project TimeGenerated, DeviceName, AccountName, FileName, ProcessCommandLine, InitiatingProcessFileName